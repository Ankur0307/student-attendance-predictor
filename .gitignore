# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Trained model artefacts (regenerated by running main.py --mode train) ─────
model/*.joblib
model/reports/

# ── Large dataset (too big for GitHub — share via Google Drive/Kaggle) ────────
*.csv

# ── IDE / OS files ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Secrets / env ─────────────────────────────────────────────────────────────
.env
*.env

# ── Jupyter notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
